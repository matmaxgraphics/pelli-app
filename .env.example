# Copy to .env.local and fill in from your Supabase project (Settings -> API).
# Both are safe to expose to the browser — access is governed by the RLS
# policies in supabase/schema.sql, not by key secrecy.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The deployed MovieNightKeepsake contract on Monad testnet (Feature 6).
# Optional: until it's set, the Summary shows the keepsake as "coming online"
# and the rest of the app works normally. Fill in after deploying via Remix.
NEXT_PUBLIC_KEEPSAKE_ADDRESS=

# Private key used by scripts/compile-and-deploy.js to deploy the contract.
DEPLOYER_PRIVATE_KEY=
